# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# For backend API and Edge Functions (not sent to frontend)
SERVICE_ROLE_KEY=your_service_role_key

# Stripe Live Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Product/Price IDs
VITE_BASIC_MONTHLY_PRICE=price_...
VITE_BASIC_YEARLY_PRICE=price_...
VITE_ADVANCED_MONTHLY_PRICE=price_...
VITE_ADVANCED_YEARLY_PRICE=price_...

# Standalone weekly newsletter (Stripe recurring prices; must match Edge Function NEWSLETTER_*_PRICE_ID)
VITE_NEWSLETTER_MONTHLY_PRICE=price_...
VITE_NEWSLETTER_YEARLY_PRICE=price_...

# Tolt affiliate (optional – set to enable referral tracking and 30-day affiliate trial)
VITE_TOLT_PUBLIC_ID=

# For testing (optional)
VITE_TESTING_PUBLISHABLE_KEY=pk_test_...
VITE_TESTING_SECRET_KEY=sk_test_...
